# Compiled binaries
bin/
*.exe
*.test
tubo
dummy-api-server

# Go build artifacts
*.out
go.*.sum
go.work.sum

# Vendor directory (if vendoring dependencies)
vendor/

# Log files
*.log

# Configuration secrets — NEVER commit these
*.key
*.pem
secrets*
*.secret
*.env
.env.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Build tool caches
build/
dist/

# Temporary/generated files
tmp/
temp/
generated/

# Coverage reports
*.cover
coverage.out

# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Python caches / scratch benchmark outputs
__pycache__/
*.pyc
tests/perf/results/*/.tmp-running/
