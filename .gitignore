*.key
*.pem
secrets*
*.secret
*.env
.env.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Build tool caches
build/
dist/

# Temporary files
tmp/
temp/

# Coverage reports
*.cover
coverage.out
